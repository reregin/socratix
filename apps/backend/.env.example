# Server
PORT=3000

# Database (Supabase PostgreSQL)
# Example: postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=""

# Cache / Ephemeral State (Redis - Upstash or direct Redis)
# Example: rediss://default:[YOUR-PASSWORD]@[REGION].redis.upstash.io:6379
REDIS_URL=""

# Groq API Key (Dapatkan dari https://console.groq.com)
GROQ_API_KEY=gsk_your_api_key_here

# Groq Model (Default ke Google Gemma 2 9B)
# Pilihan lain: llama-3.3-70b-versatile, mixtral-8x7b-32768
GROQ_MODEL=gemma2-9b-it

# Parameter Generasi
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=512
